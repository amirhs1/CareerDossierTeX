%% careerdossier-theme owns the semantic colour, rule, and link tokens. Colour
%% never carries meaning by itself; these tokens exist so components and
%% classes do not hard-code colours.

\NeedsTeXFormat{LaTeX2e}[2022-06-01]
\ProvidesExplPackage {careerdossier-theme} {2026-07-22} {0.5.0}
  {CareerDossierTeX semantic colour, rule, and link themes}

\RequirePackage { l3keys2e }
\RequirePackage { xcolor }

\tl_new:N \l__cdossier_theme_name_tl
\tl_new:N \l__cdossier_theme_accent_tl
\bool_new:N \l__cdossier_theme_accent_explicit_bool
\tl_set:Nn \l__cdossier_theme_name_tl { monochrome }
\tl_set:Nn \l__cdossier_theme_accent_tl { navy }

\msg_new:nnnn { careerdossier-theme } { unknown-option }
  { Unknown~package~option~'#1'~for~careerdossier-theme. }
  {
    Supported~options~are~'theme'~(monochrome,~accent)~and~
    'accent'~(navy,~teal,~magenta).
  }

\msg_new:nnnn { careerdossier-theme } { accent-without-theme }
  { The~'accent'~option~requires~'theme=accent'. }
  { Add~'theme=accent'~or~remove~the~'accent'~option. }

\keys_define:nn { cdossier / theme }
  {
    theme .choices:nn =
      { monochrome , accent }
      { \tl_set_eq:NN \l__cdossier_theme_name_tl \l_keys_choice_tl } ,
    theme .value_required:n = true ,
    accent .choices:nn =
      { navy , teal , magenta }
      {
        \tl_set_eq:NN \l__cdossier_theme_accent_tl \l_keys_choice_tl
        \bool_set_true:N \l__cdossier_theme_accent_explicit_bool
      } ,
    accent .value_required:n = true ,
    unknown .code:n =
      { \msg_error:nnx { careerdossier-theme } { unknown-option }
          { \l_keys_key_str } } ,
  }
\ProcessKeysOptions { cdossier / theme }
\bool_if:NT \l__cdossier_theme_accent_explicit_bool
  {
    \str_if_eq:VnF \l__cdossier_theme_name_tl { accent }
      { \msg_error:nn { careerdossier-theme } { accent-without-theme } }
  }

%% ---------------------------------------------------------------------------
%% Monochrome palette. Body text is black; the muted grey is dark enough to
%% keep at least 4.5:1 contrast on white (0.30 grey is about 8.5:1), so it is
%% used only for de-emphasis, never to carry meaning on its own.
%% ---------------------------------------------------------------------------
\definecolor { cdossier-primary } { gray } { 0 }
\definecolor { cdossier-text }    { gray } { 0 }
\definecolor { cdossier-muted }   { gray } { 0.30 }
\definecolor { cdossier-rule }    { gray } { 0 }
\definecolor { cdossier-link }    { gray } { 0 }

%% Link accents occupy a bounded luminance range: each remains at least 4.5:1
%% against white and 3:1 against adjacent black text, including the recorded
%% full-severity CVD simulations. All non-link semantic colours retain the
%% monochrome palette in every theme.
\definecolor { cdossier-accent-navy }   { HTML } { 006FB9 }
\definecolor { cdossier-accent-teal }   { HTML } { 007A78 }
\definecolor { cdossier-accent-magenta }{ HTML } { C31E99 }

\str_if_eq:VnT \l__cdossier_theme_name_tl { accent }
  {
    \str_case:Vn \l__cdossier_theme_accent_tl
      {
        { navy }    { \colorlet { cdossier-link } { cdossier-accent-navy } }
        { teal }    { \colorlet { cdossier-link } { cdossier-accent-teal } }
        { magenta } { \colorlet { cdossier-link } { cdossier-accent-magenta } }
      }
  }

%% ---------------------------------------------------------------------------
%% Public semantic colour tokens, usable as grouped switches:
%%   {\CDossierMutedColor secondary text}
%% ---------------------------------------------------------------------------
\NewDocumentCommand \CDossierPrimaryColor { } { \color { cdossier-primary } }
\NewDocumentCommand \CDossierTextColor    { } { \color { cdossier-text }    }
\NewDocumentCommand \CDossierMutedColor   { } { \color { cdossier-muted }   }
\NewDocumentCommand \CDossierRuleColor    { } { \color { cdossier-rule }    }
\NewDocumentCommand \CDossierLinkColor    { } { \color { cdossier-link }    }

%% ---------------------------------------------------------------------------
%% Link colour is the only difference between themes:
%% - monochrome: black text without a border or underline; and
%% - accent: coloured text without a border or underline.
%%
%% Visible URLs, identifiers, and descriptive labels remain present, so colour
%% is not the only carrier of link meaning.
%% \urlstyle{same} keeps \url/\nolinkurl text in the surrounding font instead of
%% typewriter, so breakable contact URLs do not switch to a monospace face.
%% The hook applies whenever hyperref loads, regardless of load order.
%% ---------------------------------------------------------------------------
\AddToHook { package/hyperref/after }
  {
    \hypersetup
      {
        colorlinks = true ,
        allcolors = cdossier-link ,
        pdfborder = { 0~0~0 }
      }
    \urlstyle { same }
  }
