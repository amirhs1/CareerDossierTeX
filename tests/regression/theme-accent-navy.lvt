% theme-accent-navy.lvt — default accent palette and link presentation.
\input{regression-test}
\documentclass{article}
\usepackage[theme=accent]{careerdossier-theme}

\ExplSyntaxOn
\cs_new_protected:Npn \cdossiertestColor #1
  {
    \extractcolorspec{#1}\l_tmpa_tl
    \TYPE{ #1 = \l_tmpa_tl }
  }
\cs_new_protected:Npn \cdossiertest_hypersetup:n #1
  { \TYPE{ hypersetup = #1 } }
\cs_set_eq:NN \hypersetup \cdossiertest_hypersetup:n
\cs_set_protected:Npn \urlstyle #1 { \TYPE{ urlstyle = #1 } }
\ExplSyntaxOff

\begin{document}
\START
\TEST{accent-defaults-to-navy}{
  \cdossiertestColor{cdossier-text}
  \cdossiertestColor{cdossier-primary}
  \cdossiertestColor{cdossier-muted}
  \cdossiertestColor{cdossier-rule}
  \cdossiertestColor{cdossier-link}
}
\TEST{accent-link-presentation}{
  \UseHook{package/hyperref/after}
}
\END
