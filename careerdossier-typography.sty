%% careerdossier-typography owns the LuaLaTeX engine check, fontspec loading,
%% the portable default fonts, and the semantic text roles. It carries no
%% colour (see careerdossier-theme) and no page geometry (see the classes).

\NeedsTeXFormat{LaTeX2e}[2022-06-01]
\ProvidesExplPackage {careerdossier-typography} {2026-07-20} {0.4.0}
  {CareerDossierTeX LuaLaTeX engine guard, portable fonts, and semantic text roles}

%% ---------------------------------------------------------------------------
%% Engine guard: LuaLaTeX only. Fail early and clearly.
%% ---------------------------------------------------------------------------
\msg_new:nnn { careerdossier-typography } { engine }
  {
    CareerDossierTeX~requires~LuaLaTeX. \\
    Compile~with~lualatex,~not~xelatex~or~pdflatex.
  }
\sys_if_engine_luatex:F
  { \msg_fatal:nn { careerdossier-typography } { engine } }

%% ---------------------------------------------------------------------------
%% LuaHBTeX emits real interword spaces in the PDF text layer, so this package
%% needs no engine-specific ActualText workaround. Optional ligatures and
%% alternates remain disabled below to keep glyph-to-Unicode mapping simple.
%% ---------------------------------------------------------------------------

%% ---------------------------------------------------------------------------
%% Fonts. Conservative Latin defaults: disable optional ligature and alternate
%% substitutions that can extract as Private Use Area characters, and use
%% lining figures. See the ATS guide, section 4.4.
%% ---------------------------------------------------------------------------
\RequirePackage { fontspec }

\defaultfontfeatures+
  {
    Ligatures = { CommonOff , ContextualOff , DiscretionaryOff , HistoricOff } ,
    Numbers   = Lining ,
  }

%% Portable, freely redistributable TeX Live fonts, resolved by file name
%% through luaotfload so the build does not depend on OS-installed fonts. All
%% four faces are explicit.
%%   body / serif : TeX Gyre Termes (Times-like)
%%   headings / sans : TeX Gyre Heros (Helvetica-like)
\setmainfont { texgyretermes }
  [
    Extension      = .otf ,
    UprightFont    = *-regular ,
    BoldFont       = *-bold ,
    ItalicFont     = *-italic ,
    BoldItalicFont = *-bolditalic ,
  ]
\setsansfont { texgyreheros }
  [
    Extension      = .otf ,
    UprightFont    = *-regular ,
    BoldFont       = *-bold ,
    ItalicFont     = *-italic ,
    BoldItalicFont = *-bolditalic ,
  ]

%% ---------------------------------------------------------------------------
%% Semantic text roles. These describe meaning, not a fixed size; the classes
%% add size and spacing. Colour is applied separately through the theme tokens.
%% ---------------------------------------------------------------------------
\NewDocumentCommand \CDossierNameStyle       { } { \sffamily \bfseries }
\NewDocumentCommand \CDossierHeadlineStyle   { } { \sffamily \mdseries }
\NewDocumentCommand \CDossierSectionStyle    { } { \sffamily \bfseries }
\NewDocumentCommand \CDossierEntryTitleStyle { } { \rmfamily \bfseries }
\NewDocumentCommand \CDossierBodyStyle       { } { \rmfamily \normalfont }
\NewDocumentCommand \CDossierMutedStyle      { } { \rmfamily \itshape }

%% ---------------------------------------------------------------------------
%% Optional tagged-PDF helpers.  \DocumentMetadata{tagging=on} must be placed
%% before \documentclass, so these interfaces are deliberately dormant for an
%% ordinary build: the kernel's inactive tagging branch renders only its input.
%% They use the supported kernel/tagpdf interfaces only.
%% ---------------------------------------------------------------------------
\cs_new_protected:Npn \__cdossier_typography_artifact:nn #1#2
  {
    \tag_if_active:TF
      {
        \tag_mc_artifact_group_begin:n {#1}
        #2
        \tag_mc_artifact_group_end:
      }
      { #2 }
  }
\cs_new_protected:Npn \__cdossier_typography_layout_artifact:n #1
  { \__cdossier_typography_artifact:nn { layout } {#1} }

%% Render a display heading with the class-provided visual formatting.  The
%% tagged branch temporarily disables automatic paragraph tagging so the line
%% becomes a heading structure directly, rather than a heading nested inside a
%% paragraph.  All commands used here are public kernel/tagpdf interfaces.
\cs_new_protected:Npn \__cdossier_typography_heading:n #1
  {
    \tag_if_active:TF
      {
        \UseTaggingSocket { para/off }
        \noindent
        \tag_struct_begin:n { tag = \UseStructureName { sec/1/title } }
        \tag_mc_begin:n { }
        #1
        \tag_mc_end:
        \tag_struct_end:
        \par \nobreak
        \UseTaggingSocket { para/restore }
      }
      {
        \noindent #1
        \par \nobreak
      }
  }
