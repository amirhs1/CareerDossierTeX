%% careerdossier-typography owns the XeLaTeX engine check, fontspec loading,
%% the portable default fonts, and the semantic text roles. It carries no
%% colour (see careerdossier-theme) and no page geometry (see the classes).

\NeedsTeXFormat{LaTeX2e}[2022-06-01]
\ProvidesExplPackage {careerdossier-typography} {2026-07-17} {0.2.0}
  {CareerDossierTeX XeLaTeX engine guard, portable fonts, and semantic text roles}

%% ---------------------------------------------------------------------------
%% Engine guard: XeLaTeX only. Fail early and clearly.
%% ---------------------------------------------------------------------------
\msg_new:nnn { careerdossier-typography } { engine }
  {
    CareerDossierTeX~requires~XeLaTeX. \\
    Compile~with~xelatex,~not~pdflatex~or~lualatex.
  }
\sys_if_engine_xetex:F
  { \msg_fatal:nn { careerdossier-typography } { engine } }

%% ---------------------------------------------------------------------------
%% \XeTeXgenerateactualtext is deliberately NOT enabled.
%%
%% It wraps every word in its own /Span << /ActualText (word) >> BDC ... EMC
%% sequence with no space token between adjacent spans. Consumers that treat
%% /ActualText as authoritative and concatenate the strings — Apple PDFKit, and
%% so Preview, Quick Look, Spotlight, Safari, and ordinary macOS copy/paste —
%% lose the interword space and merge adjacent words ("Research& Development").
%% Poppler and MuPDF fall back to glyph geometry and are unaffected, which is
%% why a Poppler-only gate never caught it.
%%
%% Its protective value here is small: this package disables every optional
%% ligature and alternate below, which is the main case /ActualText guards
%% against. See the ATS guide, section 4.5, and tests/extraction/run.sh, which
%% fails if the setting returns.
%% ---------------------------------------------------------------------------

%% ---------------------------------------------------------------------------
%% Fonts. Conservative Latin defaults: disable optional ligature and alternate
%% substitutions that can extract as Private Use Area characters, and use
%% lining figures. See the ATS guide, section 4.4.
%% ---------------------------------------------------------------------------
\RequirePackage { fontspec }

\defaultfontfeatures+
  {
    Ligatures = { CommonOff , ContextualOff , DiscretionaryOff , HistoricOff } ,
    Numbers   = Lining ,
  }

%% Portable, freely redistributable TeX Live fonts, loaded by file name so the
%% build does not depend on OS-installed fonts. All four faces are explicit.
%%   body / serif : TeX Gyre Termes (Times-like)
%%   headings / sans : TeX Gyre Heros (Helvetica-like)
\setmainfont { texgyretermes }
  [
    Extension      = .otf ,
    UprightFont    = *-regular ,
    BoldFont       = *-bold ,
    ItalicFont     = *-italic ,
    BoldItalicFont = *-bolditalic ,
  ]
\setsansfont { texgyreheros }
  [
    Extension      = .otf ,
    UprightFont    = *-regular ,
    BoldFont       = *-bold ,
    ItalicFont     = *-italic ,
    BoldItalicFont = *-bolditalic ,
  ]

%% ---------------------------------------------------------------------------
%% Semantic text roles. These describe meaning, not a fixed size; the classes
%% add size and spacing. Colour is applied separately through the theme tokens.
%% ---------------------------------------------------------------------------
\NewDocumentCommand \CDossierNameStyle       { } { \sffamily \bfseries }
\NewDocumentCommand \CDossierHeadlineStyle   { } { \sffamily \mdseries }
\NewDocumentCommand \CDossierSectionStyle    { } { \sffamily \bfseries }
\NewDocumentCommand \CDossierEntryTitleStyle { } { \rmfamily \bfseries }
\NewDocumentCommand \CDossierBodyStyle       { } { \rmfamily \normalfont }
\NewDocumentCommand \CDossierMutedStyle      { } { \rmfamily \itshape }
