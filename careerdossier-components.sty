\NeedsTeXFormat{LaTeX2e}[2022-06-01]
\ProvidesExplPackage {careerdossier-components} {2026-07-24} {0.5.0}
  {CareerDossierTeX shared identity block, contact line, and link wrappers}

\RequirePackage { careerdossier-base }
\RequirePackage { careerdossier-typography }
\RequirePackage { careerdossier-theme }

%% ---------------------------------------------------------------------------
%% Contact line.
%%
%% Fields are rendered in one fixed, logical order; missing fields are skipped
%% and separators are inserted only between rendered items, so no stray or
%% duplicated separators can appear.
%% ---------------------------------------------------------------------------
\clist_const:Nn \c__cdossier_components_contactorder_clist
  { email , phone , location , website , linkedin , github , scholar , orcid }

\tl_new:N   \l__cdossier_components_disp_tl
\tl_new:N   \l__cdossier_components_url_tl
\str_new:N  \l__cdossier_components_scheme_str
\bool_new:N \l__cdossier_components_printed_bool
\tl_new:N   \l__cdossier_components_label_tl

%% Opt-in contact-field labels (issue #95). A screen reader announces the email
%% and website as links, but a phone number is read as bare digits with nothing
%% conveying what it is; plain extraction and ATS parsers see no link
%% annotations at all. A visible text label is the one mechanism that works in
%% every consumer, including untagged output, so it is the primary fix.
%%
%% Only the fields whose nature the value itself does not convey are labelled:
%% email, phone, and website. The linkedin, github, and scholar values begin
%% with their service's domain, orcid always carries its own label (below), and
%% a location value is a place name. Labels are fixed English strings; the
%% project is English-only (docs/ARCHITECTURE.md).
\prop_const_from_keyval:Nn \c__cdossier_components_labels_prop
  {
    email   = Email ,
    phone   = Phone ,
    website = Website ,
  }

%% Leaf: typeset one label word tied to the value that follows. A label is
%% meaningful content, never a layout artifact: it must reach the structure
%% tree and the extracted text, unlike the separators below.
\cs_new_protected:Npn \__cdossier_components_labeltext:n #1
  { #1:\nobreakspace }
\cs_generate_variant:Nn \__cdossier_components_labeltext:n { V }

%% Emit the label for a field, only when labels are enabled and the field has
%% one. Called from the per-field renderer, so an absent field can never leave
%% an orphan label.
\cs_new_protected:Npn \__cdossier_components_label:n #1
  {
    \bool_if:NT \g__cdossier_base_contactlabels_bool
      {
        \prop_get:NnNT \c__cdossier_components_labels_prop {#1}
          \l__cdossier_components_label_tl
          { \__cdossier_components_labeltext:V \l__cdossier_components_label_tl }
      }
  }

%% Separator between present contact items: a spaced vertical bar.
\cs_new_protected:Npn \__cdossier_components_sep:
  { \__cdossier_typography_layout_artifact:n { ~|~ } }

%% Link wrapper. The visible identifier is wrapped in \nolinkurl so long URLs
%% gain URL-aware breakpoints instead of overrunning the margin; the theme sets
%% \urlstyle{same} so the text stays in the body font rather than switching to
%% monospace. Degrades to plain visible text when hyperref is absent, so the
%% identifier is always present and extractable.
\cs_new_protected:Npn \__cdossier_components_link:nn #1#2
  { \cs_if_exist:NTF \href { \href {#1} { \nolinkurl {#2} } } { #2 } }
\cs_generate_variant:Nn \__cdossier_components_link:nn { VV }

%% Email: a mailto: link over the visible address.
\cs_new_protected:Npn \__cdossier_components_mail:n #1
  {
    \tl_set:Nx \l__cdossier_components_disp_tl { \CDossierFieldValue {#1} }
    \tl_set:Nx \l__cdossier_components_url_tl  { mailto: \l__cdossier_components_disp_tl }
    \__cdossier_components_link:VV \l__cdossier_components_url_tl \l__cdossier_components_disp_tl
  }

%% Web profile: a link over the visible URL/identifier. The href target is
%% normalized to include a scheme; the displayed text is left exactly as given.
%% Input is expected as a full path such as github.com/name (not a bare handle).
\cs_new_protected:Npn \__cdossier_components_web:n #1
  {
    \tl_set:Nx \l__cdossier_components_disp_tl { \CDossierFieldValue {#1} }
    \tl_set_eq:NN \l__cdossier_components_url_tl \l__cdossier_components_disp_tl
    %% Detect an existing scheme by string, not by token list: the value's colon
    %% is an ordinary character (catcode 12) while a literal colon in this
    %% package is a letter (catcode 11) under expl3, so a catcode-sensitive
    %% \tl_if_in: would never match and would double the scheme.
    \str_set:NV \l__cdossier_components_scheme_str \l__cdossier_components_url_tl
    \str_if_in:NnF \l__cdossier_components_scheme_str { :// }
      { \tl_put_left:Nn \l__cdossier_components_url_tl { https:// } }
    \__cdossier_components_link:VV \l__cdossier_components_url_tl \l__cdossier_components_disp_tl
  }

%% ORCID: unlike an ordinary web-profile value, a bare ORCID identifier has a
%% documented canonical destination. Keep the identifier visible with a text
%% label, so its meaning does not depend on a colour, icon, or link annotation.
\cs_new_protected:Npn \__cdossier_components_orcid:
  {
    \tl_set:Nx \l__cdossier_components_disp_tl { \CDossierFieldValue { orcid } }
    \tl_set_eq:NN \l__cdossier_components_url_tl \l__cdossier_components_disp_tl
    \str_set:NV \l__cdossier_components_scheme_str \l__cdossier_components_url_tl
    \str_if_in:NnF \l__cdossier_components_scheme_str { :// }
      {
        \str_if_in:NnTF \l__cdossier_components_scheme_str { orcid.org/ }
          { \tl_put_left:Nn \l__cdossier_components_url_tl { https:// } }
          { \tl_put_left:Nn \l__cdossier_components_url_tl { https://orcid.org/ } }
      }
    \cs_if_exist:NTF \href
      {
        \href { \l__cdossier_components_url_tl }
          { ORCID:\nobreakspace \nolinkurl { \l__cdossier_components_disp_tl } }
      }
      { ORCID:\nobreakspace \l__cdossier_components_disp_tl }
  }

%% Render one contact field: an optional identifying label, then the value —
%% linked for the web-facing fields, plain text for the rest.
\cs_new_protected:Npn \__cdossier_components_render:n #1
  {
    \__cdossier_components_label:n {#1}
    \str_case:nnF {#1}
      {
        { email }    { \__cdossier_components_mail:n { email }    }
        { website }  { \__cdossier_components_web:n  { website }  }
        { linkedin } { \__cdossier_components_web:n  { linkedin } }
        { github }   { \__cdossier_components_web:n  { github }   }
        { scholar }  { \__cdossier_components_web:n  { scholar }  }
        { orcid }    { \__cdossier_components_orcid:              }
      }
      { \CDossierPrintField {#1} }
  }

%% Build a contact line from a caller-supplied ordered field list. This keeps
%% link normalization and separator insertion component-owned while allowing a
%% document class to display only the contacts relevant to its document model.
\cs_new_protected:Npn \__cdossier_components_contactline:N #1
  {
    \bool_set_false:N \l__cdossier_components_printed_bool
    \clist_map_inline:Nn #1
      {
        \CDossierIfFieldTF {##1}
          {
            \bool_if:NT \l__cdossier_components_printed_bool
              { \__cdossier_components_sep: }
            \__cdossier_components_render:n {##1}
            \bool_set_true:N \l__cdossier_components_printed_bool
          }
          { }
      }
  }

%% Default identity contact line used by the released résumé, CV, and letter
%% classes. Its order and output remain unchanged.
\cs_new_protected:Npn \__cdossier_components_contactline:
  {
    \__cdossier_components_contactline:N
      \c__cdossier_components_contactorder_clist
  }

%% ---------------------------------------------------------------------------
%% Identity block.
%%
%% A centered block of name, optional headline, and the contact line, shared by
%% the résumé header and the cover-letter sender identity. Requires `name`.
%% ---------------------------------------------------------------------------
\NewDocumentCommand \MakeCDossierHeader { }
  {
    \__cdossier_base_require_name:N \MakeCDossierHeader
    \begin { center }
      { \CDossierNameStyle \Huge \CDossierPrintField { name } \par }
      \CDossierIfFieldTF { headline }
        {
          \smallskip
          { \CDossierHeadlineStyle \large \CDossierPrintField { headline } \par }
        }
        { }
      \smallskip
      { \CDossierBodyStyle \small \__cdossier_components_contactline: \par }
    \end { center }
  }

%% ---------------------------------------------------------------------------
%% Entry heading primitive.
%%
%% Renders a single entry heading shared by résumé sections (experience,
%% education, projects, ...). It takes a required title and up to three optional
%% metadata fields, and carries no page geometry or vertical spacing of its own:
%% the owning class decides how much room surrounds an entry. Layout:
%%
%%   Title .......................................... dates
%%   Organization ................................... location
%%
%% Each optional cell is emitted only when its value is nonblank, so a missing
%% field leaves no dangling punctuation, separator, or empty second line. The
%% second line is emitted only when organization or location is present.
%%
%% #1 title (required, nonblank), #2 organization, #3 location, #4 dates.
%% ---------------------------------------------------------------------------
\cs_new_protected:Npn \__cdossier_components_entryhead:nnnn #1#2#3#4
  {
    \noindent
    { \CDossierEntryTitleStyle #1 }
    \tl_if_blank:nF {#4}
      { \hfill { \CDossierMutedStyle #4 } }
    \par
    \bool_lazy_or:nnT
      { ! \tl_if_blank_p:n {#2} }
      { ! \tl_if_blank_p:n {#3} }
      {
        \noindent
        \tl_if_blank:nF {#2} { { \CDossierBodyStyle #2 } }
        \tl_if_blank:nF {#3} { \hfill { \CDossierMutedStyle #3 } }
        \par
      }
  }
\cs_generate_variant:Nn \__cdossier_components_entryhead:nnnn { VVVV }

%% ---------------------------------------------------------------------------
%% PDF document metadata.
%%
%% A PDF with no /Title shows its filename in viewer tab bars and document
%% properties, and /Lang is the document's natural-language declaration. Both
%% are derivable from the profile this module already owns, so they are set
%% here rather than duplicated in every class.
%%
%% Timing: the values are applied at \begin{document}. They cannot be applied
%% earlier, because the class loads hyperref while the profile is still empty --
%% \CDossierSetup does not run until the preamble.
%%
%% Precedence: each field is written only when the document has not already set
%% it, so a user's own \hypersetup wins wherever it appears in the preamble.
%% That matters because the documented template in docs/ATS-EXTRACTION.md
%% places \hypersetup *before* \CDossierSetup; a blind write here would silently
%% discard it.
%%
%% hyperref is not loaded by this module (the classes own it), so every entry
%% point is guarded and the package still loads without it.
%% ---------------------------------------------------------------------------
\tl_new:N \l__cdossier_components_doctype_tl
\tl_new:N \l__cdossier_components_pdfname_tl

%% Declare the kind of document being produced. The owning class calls this, so
%% a resume and a letter built from one profile do not receive identical PDF
%% titles. Absent or blank, the title falls back to the name alone.
\cs_new_protected:Npn \__cdossier_components_doctype:n #1
  { \tl_set:Nn \l__cdossier_components_doctype_tl {#1} }

%% Has the document already supplied this hyperref metadata field?
%%
%% This reads hyperref's internals, so the observed states are spelled out
%% rather than assumed. On a fresh hyperref, \@pdftitle and \@pdfauthor are
%% defined and empty, while \@pdflang is \relax. expl3 reports a \relax-meaning
%% control sequence as *not existing*, so the \relax and never-defined cases
%% collapse into the same branch -- and both mean the document has not supplied
%% a value. Only a defined, non-empty value counts as user-supplied.
%%
%% Getting this backwards is silent: the field simply never reaches the PDF, and
%% no log records it. tests/regression/components-pdfmeta.lvt pins all three
%% states.
%%
%% Emptiness is tested through the macro's expansion rather than with
%% \tl_if_empty:c, which compares meaning against \c_empty_tl and therefore
%% reports an empty \long macro as non-empty. hyperref's fields happen to be
%% non-long today, so \tl_if_empty:c would work by luck; expanding first does
%% not depend on that.
%%
%% These names are read, never redefined.
\prg_new_protected_conditional:Npnn \__cdossier_components_hyp_if_unset:n #1
  { T , TF }
  {
    \cs_if_exist:cTF {#1}
      {
        \exp_args:Ne \tl_if_empty:nTF { \use:c {#1} }
          { \prg_return_true: }
          { \prg_return_false: }
      }
      { \prg_return_true: }
  }

%% Build "Doctype -- Name", or just "Name" when the class declared no doctype.
\cs_new_protected:Npn \__cdossier_components_pdftitle:
  {
    \tl_set:Nx \l__cdossier_components_pdfname_tl { \CDossierFieldValue { name } }
    \tl_if_blank:VF \l__cdossier_components_doctype_tl
      {
        \tl_put_left:Nx \l__cdossier_components_pdfname_tl
          { \l__cdossier_components_doctype_tl \c_space_tl -- \c_space_tl }
      }
  }

%% Apply the derived metadata. Only ever called when hyperref is present.
\cs_new_protected:Npn \__cdossier_components_pdfmeta:
  {
    \CDossierIfFieldTF { name }
      {
        \__cdossier_components_hyp_if_unset:nT { @pdftitle }
          {
            \__cdossier_components_pdftitle:
            \hypersetup { pdftitle = { \l__cdossier_components_pdfname_tl } }
          }
        \__cdossier_components_hyp_if_unset:nT { @pdfauthor }
          { \hypersetup { pdfauthor = { \CDossierFieldValue { name } } } }
      }
      { }
    %% v0.1.0 is English-only (see docs/ARCHITECTURE.md); there is no language
    %% key to route this through yet.
    \__cdossier_components_hyp_if_unset:nT { @pdflang }
      { \hypersetup { pdflang = en } }
  }

\AddToHook { begindocument }
  { \cs_if_exist:NT \hypersetup { \__cdossier_components_pdfmeta: } }
